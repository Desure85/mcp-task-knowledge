{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/__tests__/**",
    "src/types/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.e2e.ts"
  ]
}
